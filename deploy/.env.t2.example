# =============================================================================
# Sub2API t2.llmwc.com Isolated Instance Environment
# =============================================================================
# Copy to .env.t2, replace every change_this_* value, then start with:
#   docker compose --env-file .env.t2 -f docker-compose.t2.yml up -d
# =============================================================================

# Host binding for the t2 instance. Keep this on localhost when Caddy/Nginx is
# the public TLS entrypoint.
T2_BIND_HOST=127.0.0.1
T2_SERVER_PORT=18082

# Use a fixed release image in production when possible. For local validation,
# this can be changed to a locally built image such as deploy-sub2api:latest.
SUB2API_IMAGE=weishaw/sub2api:latest

SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# Public URL used by generated external links such as password reset emails.
SERVER_FRONTEND_URL=https://t2.llmwc.com

# PostgreSQL for t2 only. Do not reuse the main-domain database credentials.
POSTGRES_USER=sub2api_t2
POSTGRES_PASSWORD=change_this_t2_postgres_password
POSTGRES_DB=sub2api_t2
DATABASE_MAX_OPEN_CONNS=128
DATABASE_MAX_IDLE_CONNS=64
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# Redis for t2 only. This compose file runs a separate Redis container and data
# directory, so t2 cache/session data cannot mix with the main domain.
REDIS_PASSWORD=change_this_t2_redis_password
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=64
REDIS_ENABLE_TLS=false

# The t2 admin account is created only in the t2 database on first startup.
# It is not an admin on the main domain unless you separately create it there.
ADMIN_EMAIL=admin@t2.llmwc.com
ADMIN_PASSWORD=change_this_t2_admin_password

# Use fixed, unique secrets for t2. Never copy the main-domain secrets here.
JWT_SECRET=change_this_t2_jwt_secret_hex_64
JWT_EXPIRE_HOUR=24
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=0
TOTP_ENCRYPTION_KEY=change_this_t2_totp_encryption_key_hex_64

# Optional OAuth/provider secrets for t2. Keep blank unless t2 needs its own
# OAuth integrations.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
GEMINI_QUOTA_POLICY=
GEMINI_CLI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_USER_AGENT_VERSION=

# Optional proxy used for online update checks and pricing downloads.
UPDATE_PROXY_URL=
